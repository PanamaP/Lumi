{
  "$schema": "http://json.schemastore.org/template",
  "author": "Lumi",
  "classifications": ["Desktop", "GUI", "Lumi"],
  "identity": "Lumi.Templates.App",
  "name": "Lumi App",
  "shortName": "lumi",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "LumiApp.1",
  "preferNameDirectory": true,
  "symbols": {
    "framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        { "choice": "net10.0", "description": ".NET 10" }
      ],
      "defaultValue": "net10.0",
      "replaces": "net10.0"
    }
  },
  "sources": [
    {
      "modifiers": [
        { "exclude": ["bin/**", "obj/**"] }
      ]
    }
  ]
}
