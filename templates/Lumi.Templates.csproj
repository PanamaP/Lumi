<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>Lumi.Templates</PackageId>
    <PackageVersion>0.1.0</PackageVersion>
    <Title>Lumi Project Templates</Title>
    <Authors>Lumi</Authors>
    <Description>Project templates for the Lumi GUI framework. Use 'dotnet new lumi' to create a new Lumi desktop app.</Description>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="lumi-app\**\*" Exclude="lumi-app\bin\**;lumi-app\obj\**" />
    <Compile Remove="**\*" />
  </ItemGroup>

</Project>
